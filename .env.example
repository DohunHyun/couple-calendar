# === OAuth (provider 콘솔에서 발급) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8080/api

# === Backend secrets (운영에서는 반드시 주입) ===
# JWT_SECRET: 미설정 시 로컬 개발용 더미 기본값이 쓰임. 운영에서는 충분히 긴 랜덤 문자열로 반드시 override.
JWT_SECRET=
# DB 접속 (미설정 시 localhost root/root 기본값 사용)
DB_URL=jdbc:mysql://localhost:3306/couple_calendar?createDatabaseIfNotExist=true&serverTimezone=Asia/Seoul
DB_USERNAME=root
DB_PASSWORD=root
